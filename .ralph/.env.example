# Open Ralph / OpenCode only — sourced by .ralph/ralph.sh (set -a). Do not commit.
# Project app secrets (e.g. Telegram) belong in the repository root `.env`, not here.

VLLM_API_KEY=vllm-api-key

# OpenCode runs tools only when vLLM returns non-empty tool_calls. Qwen2.5-Coder often puts
# tool-shaped text in assistant content instead; Hermes does not parse it (vLLM #10952, #32926).
# --enable-auto-tool-choice --tool-call-parser hermes is correct for Qwen2.5-Instruct (non-Coder).
# For agents, prefer Qwen2.5-*-Instruct (non-Coder), e.g. 7B/14B-AWQ, or a hosted API.
# RALPH_ABORT_ON_FAKE_TOOLS=1

# ── vLLM pre-flight check ───────────────────────────────────────────────────
# ./ralph.sh → .ralph/ralph.sh queries GET /v1/models for max_model_len >= RALPH_MIN_CTX.
# If WSL cannot reach 192.168.x.x from opencode.json, set the URL that works for **this** shell’s curl
# (same host as OpenCode). OpenAI-style base, e.g. http://host:8000/v1 — preflight GET ${RALPH_VLLM_URL}/models
# RALPH_VLLM_URL=http://192.168.0.10:8000/v1
# When preflight cannot reach vLLM, output tokens cap (avoid OpenCode default 32k + prompt > context):
# RALPH_FALLBACK_MAX_OUTPUT=4096
# Tighter completion budget for ~32k models (more room for tool traces in the input window):
RALPH_MAX_OUTPUT_TOKENS=4096
# RALPH_COMPLETION_HARD_CAP=8192
RALPH_MIN_CTX=4096
# How many iteration blocks stay in progress.txt before older ones move to .ralph/archive/
RALPH_ITERATION_LOG_KEEP=5
# Autocompact is ON by default. Uncomment to restore old behavior (full history every turn):
# RALPH_DISABLE_AUTOCOMPACT=1

# Must match a key under provider.vllm.models in .opencode/opencode.json AND an id from GET /v1/models.
# Default in opencode.json is vllm/Qwen/Qwen2.5-14B-Instruct-AWQ. Override if needed:
# RALPH_MODEL=vllm/Qwen/Qwen2.5-7B-Instruct-AWQ

# ── OpenCode agent config ───────────────────────────────────────────────────
# Agent: .opencode/agents/ralph.md
RALPH_AGENT=ralph

# Prompt path relative to .ralph/ (default: prompt.md there)
RALPH_PROMPT_FILE=prompt.md

# Prevent hangs from network calls during startup
OPENCODE_DISABLE_LSP_DOWNLOAD=true
OPENCODE_DISABLE_MODELS_FETCH=true
