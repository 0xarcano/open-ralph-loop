# Open Ralph / OpenCode — sourced by `.ralph/ralph.sh` (`set -a`); exports apply to `opencode run`.
# Copy to `.ralph/.env` (do not commit secrets). Project app secrets belong in repo root `.env`, not here.
# For a short starter set, see `.env.example.minimal`.

# ═══════════════════════════════════════════════════════════════════════════
# Local LLM stack (Ollama vs vLLM) — OpenAI-compatible GET …/v1/models pre-flight
# ═══════════════════════════════════════════════════════════════════════════

# Which server Ralph’s pre-flight talks to: ollama | vllm (default in this file: vllm).
# If unset: inferred from OpenCode model id — ollama/* → ollama, otherwise vllm (vllm/* or any other id uses vLLM base URL rules).
RALPH_LLM_PROVIDER=vllm

# OpenAI-compatible API base URL (must include /v1). Examples:
#   vLLM:   http://127.0.0.1:8000/v1
#   Ollama: http://127.0.0.1:11434/v1
# If unset: ollama → http://127.0.0.1:11434/v1; vllm → first baseURL in `.opencode/opencode.json` (or global opencode.json).
# RALPH_LLM_API_BASE=http://127.0.0.1:8000/v1

# Bearer token for pre-flight `curl` when the server requires `Authorization: Bearer …` (often empty for local Ollama).
RALPH_LLM_API_KEY=

# OpenCode runs tools only when the server returns non-empty `tool_calls`. Some Qwen2.5-Coder checkpoints emit
# tool-shaped text in assistant content instead; use Qwen2.5-*-Instruct (non-Coder) with vLLM
# `--enable-auto-tool-choice` and `--tool-call-parser hermes` for reliable tool calling.

# ═══════════════════════════════════════════════════════════════════════════
# RALPH_* — `opencode run` CLI (see `.ralph/ralph.sh`)
# ═══════════════════════════════════════════════════════════════════════════

# Model id (e.g. `vllm/Qwen/...` or `ollama/llama3.2`). Default: from `.opencode/opencode.json` / global config.
# RALPH_MODEL=vllm/Qwen/Qwen2.5-14B-Instruct-AWQ

# Agent name → `.opencode/agents/<name>.md` (default: ralph).
RALPH_AGENT=ralph

# Optional OpenCode attach URL (e.g. `http://localhost:4096`).
# RALPH_ATTACH=

# Prompt file: path under `.ralph/`, or absolute. Default: `prompt.md` in `.ralph/`.
# RALPH_PROMPT_FILE=prompt.md

# If `1`, exit with code 2 when model output looks like fake markdown/XML tools (local server not returning real tool_calls).
# RALPH_ABORT_ON_FAKE_TOOLS=0

# ═══════════════════════════════════════════════════════════════════════════
# RALPH_* — pre-flight (`GET …/v1/models`) & completion budget
# ═══════════════════════════════════════════════════════════════════════════

# Minimum `max_model_len` required when the server reports it (default 4096). Pre-flight fails if lower.
# Ollama’s `/v1/models` often omits `max_model_len`; Ralph then uses RALPH_FALLBACK_MAX_OUTPUT only.
RALPH_MIN_CTX=4096

# Upper bound on completion tokens after `min(max_model_len/4, RALPH_COMPLETION_HARD_CAP)` (numeric).
RALPH_MAX_OUTPUT_TOKENS=4096

# Ceiling for the `max_len/4` branch before `RALPH_MAX_OUTPUT_TOKENS` is applied (default 8192).
# RALPH_COMPLETION_HARD_CAP=8192

# When `GET …/models` fails or omits `max_model_len`, cap `OPENCODE_EXPERIMENTAL_OUTPUT_TOKEN_MAX` (default 8192).
# RALPH_FALLBACK_MAX_OUTPUT=8192

# Read-only: `ralph.sh` exports this when pre-flight reads `max_model_len`. Do not set manually.
# RALPH_MAX_MODEL_LEN=

# ═══════════════════════════════════════════════════════════════════════════
# RALPH_* — progress log & OpenCode toggles mediated by `ralph.sh`
# ═══════════════════════════════════════════════════════════════════════════

# Max **## Iteration log** blocks kept in `.ralph/progress.txt`; older blocks archived under `.ralph/archive/`.
RALPH_ITERATION_LOG_KEEP=5

# If `1`, set `OPENCODE_DISABLE_AUTOCOMPACT=true` (autocompact is ON by default without this).
# RALPH_DISABLE_AUTOCOMPACT=0

# ═══════════════════════════════════════════════════════════════════════════
# OPENCODE_* — read by OpenCode (inherited when `.env` is sourced before `opencode run`)
# ═══════════════════════════════════════════════════════════════════════════

# Max output tokens. Pre-flight may **lower** this to fit `max_model_len`; you can set a starting cap here.
# OPENCODE_EXPERIMENTAL_OUTPUT_TOKEN_MAX=4096

# Disable autocompact (only if you need full history every turn). Prefer `RALPH_DISABLE_AUTOCOMPACT=1` above.
# OPENCODE_DISABLE_AUTOCOMPACT=false

# Faster / offline-friendly startup (skip LSP server download, skip remote model list fetch).
OPENCODE_DISABLE_LSP_DOWNLOAD=true
OPENCODE_DISABLE_MODELS_FETCH=true

# Enable experimental **lsp** tool (definitions, references). See OpenCode docs / `OPENCODE_EXPERIMENTAL`.
# OPENCODE_EXPERIMENTAL_LSP_TOOL=true
# OPENCODE_EXPERIMENTAL=true

# Web search tool (Exa); only active with OpenCode provider or when set truthy.
# OPENCODE_ENABLE_EXA=0
