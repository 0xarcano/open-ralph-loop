# Minimal `.ralph/.env` — copy to `.ralph/.env` and adjust. Full variable list: `.env.example`.

# Default stack for pre-flight; use ollama for Ollama-only setups (or unset and use an ollama/… model id).
RALPH_LLM_PROVIDER=vllm

# Bearer token for pre-flight `curl` when your server requires `Authorization: Bearer …`.
RALPH_LLM_API_KEY=

RALPH_AGENT=ralph
RALPH_MAX_OUTPUT_TOKENS=4096
RALPH_MIN_CTX=4096

OPENCODE_DISABLE_LSP_DOWNLOAD=true
OPENCODE_DISABLE_MODELS_FETCH=true
